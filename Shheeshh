<script>
/* ── Stars ── */
const canvas = document.getElementById('stars');
const ctx = canvas.getContext('2d');
let stars = [];
function initStars() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
  stars = Array.from({length: 220}, () => ({
    x: Math.random() * canvas.width,
    y: Math.random() * canvas.height,
    r: Math.random() * 1.3 + 0.2,
    o: Math.random(),
    s: Math.random() * 0.006 + 0.002,
    c: Math.random() > 0.85 ? '#e8166e' : Math.random() > 0.7 ? '#0dcbdf' : '#f2f4ff'
  }));
}
function drawStars() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  stars.forEach(s => {
    s.o += s.s; if (s.o > 1 || s.o < 0) s.s *= -1;
    ctx.beginPath();
    ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
    ctx.fillStyle = s.c.replace(')', `,${s.o * 0.7})`).replace('rgb', 'rgba').replace('#f2f4ff', `rgba(242,244,255,${s.o * 0.6})`).replace('#e8166e', `rgba(232,22,110,${s.o * 0.5})`).replace('#0dcbdf', `rgba(13,203,223,${s.o * 0.5})`);
    ctx.fill();
  });
  requestAnimationFrame(drawStars);
}
initStars(); drawStars();
window.addEventListener('resize', initStars);

/* ── Age gate ── */
function enterSite() {
  const g = document.getElementById('age-gate');
  g.style.animation = 'gateOut 0.45s forwards';
  setTimeout(() => {
    g.style.display = 'none';
    document.getElementById('site').style.display = 'block';
    updateStatus();
  }, 440);
}

/* ── Open status ── */
function updateStatus() {
  const now = new Date();
  const day = now.getDay();
  const total = now.getHours() * 60 + now.getMinutes();
  // 10:00(600) to 21:55(1315)
  const isOpen = total >= 600 && total < 1315;
  const label = isOpen ? 'Open Now' : 'Currently Closed';
  ['hero-open','visit-open'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.textContent = label;
  });
  const row = document.getElementById('r' + day);
  if (row) row.classList.add('today');
}

/* ── Nav scroll ── */
window.addEventListener('scroll', () => {
  document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 40);
});

/* ── Mobile menu ── */
function toggleMenu() { document.getElementById('mobile-menu').classList.toggle('open'); }
function closeMenu() { document.getElementById('mobile-menu').classList.remove('open'); }

/* ── Newsletter ── */
function nlSignup() {
  const email = document.getElementById('nl-email').value;
  const msg = document.getElementById('nl-msg');
  if (!email || !email.includes('@')) {
    msg.style.color = 'rgba(216,218,240,0.5)';
    msg.textContent = 'Please enter a valid email address.';
    return;
  }
  msg.style.color = 'var(--cyan)';
  msg.textContent = "Signal received. Welcome aboard, astronaut.";
  document.getElementById('nl-email').value = '';
}
</script>
