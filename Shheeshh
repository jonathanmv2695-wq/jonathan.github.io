<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>The Space Station — Cannabis Dispensary · Portland, OR</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet"/>
<style>
  :root {
    --black:    #070810;
    --deep:     #0c0d1a;
    --panel:    #101222;
    --card:     #151828;
    --navy:     #1a1e38;
    --pink:     #e8166e;
    --pink-mid: #f03a84;
    --pink-pale:#fbadd4;
    --cyan:     #0dcbdf;
    --cyan-mid: #29dff0;
    --cyan-pale:#a8f0f8;
    --purple:   #6c3cbf;
    --purple-light: #9966e8;
    --white:    #f2f4ff;
    --off:      #d8daf0;
    --mid:      #7880aa;
    --muted:    #4a5070;
    --glow-p:   rgba(232,22,110,0.3);
    --glow-c:   rgba(13,203,223,0.3);
    --border-n: rgba(232,22,110,0.2);
    --border-c: rgba(13,203,223,0.2);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Space Grotesk', sans-serif;
    overflow-x: hidden;
  }

  /* ── star field ── */
  #stars {
    position: fixed; inset: 0; z-index: 0;
    pointer-events: none;
  }

  /* ── scan lines ── */
  body::after {
    content: '';
    position: fixed; inset: 0;
    background: repeating-linear-gradient(
      0deg, transparent 0px, transparent 3px,
      rgba(13,203,223,0.012) 3px, rgba(13,203,223,0.012) 4px
    );
    pointer-events: none; z-index: 0;
  }

  /* ══════════════ AGE GATE ══════════════ */
  #age-gate {
    position: fixed; inset: 0; z-index: 999;
    background: var(--deep);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; padding: 40px 24px; text-align: center;
    overflow: hidden;
  }
  /* Neon city horizon glow */
  #age-gate::before {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 40%;
    background: linear-gradient(0deg, rgba(232,22,110,0.08) 0%, transparent 100%);
    pointer-events: none;
  }
  #age-gate::after {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 40%;
    background: linear-gradient(180deg, rgba(13,203,223,0.06) 0%, transparent 100%);
    pointer-events: none;
  }
  .gate-rings {
    display: flex; align-items: center; justify-content: center;
    gap: -12px; margin-bottom: 16px; position: relative; z-index: 1;
  }
  .gate-ring {
    width: 54px; height: 54px; border-radius: 50%;
    border: 2.5px solid var(--cyan);
    box-shadow: 0 0 16px var(--glow-c), inset 0 0 8px rgba(13,203,223,0.1);
    animation: ringGlow 3s ease-in-out infinite;
    margin: 0 -6px;
  }
  .gate-ring:nth-child(2) { border-color: var(--pink); box-shadow: 0 0 16px var(--glow-p), inset 0 0 8px rgba(232,22,110,0.1); animation-delay: 1s; }
  .gate-ring:nth-child(3) { animation-delay: 2s; }
  @keyframes ringGlow { 0%,100%{opacity:1;} 50%{opacity:0.5;} }

  .gate-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.8rem, 6vw, 3.4rem);
    font-weight: 800; letter-spacing: -0.02em;
    line-height: 1.0; color: var(--white);
    position: relative; z-index: 1; margin-bottom: 4px;
  }
  .gate-title .pink { color: var(--pink); text-shadow: 0 0 24px var(--glow-p); }
  .gate-title .cyan { color: var(--cyan); text-shadow: 0 0 24px var(--glow-c); }
  .gate-sub {
    font-size: 0.68rem; font-weight: 600;
    letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--mid); margin-bottom: 28px;
    position: relative; z-index: 1;
  }
  .gate-rule {
    width: 80px; height: 1px; margin: 0 auto 24px;
    background: linear-gradient(90deg, var(--pink), var(--cyan));
    border-radius: 2px;
    box-shadow: 0 0 12px rgba(232,22,110,0.4);
    position: relative; z-index: 1;
  }
  .gate-q {
    font-size: 0.98rem; font-weight: 400;
    color: rgba(242,244,255,0.7); margin-bottom: 26px;
    position: relative; z-index: 1;
  }
  .gate-btns {
    display: flex; gap: 12px; flex-wrap: wrap;
    justify-content: center; margin-bottom: 22px;
    position: relative; z-index: 1;
  }
  .gate-yes {
    font-family: 'Syne', sans-serif;
    font-size: 0.85rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    background: linear-gradient(135deg, var(--pink), var(--purple));
    color: var(--white); border: none;
    padding: 14px 44px; border-radius: 3px;
    cursor: pointer;
    box-shadow: 0 4px 24px var(--glow-p), 0 0 0 1px rgba(232,22,110,0.3);
    transition: all 0.25s;
  }
  .gate-yes:hover { transform: translateY(-2px); box-shadow: 0 8px 36px rgba(232,22,110,0.45); }
  .gate-no {
    font-size: 0.88rem; font-weight: 500;
    background: transparent; color: var(--muted);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 14px 32px; border-radius: 3px; cursor: pointer;
    letter-spacing: 0.04em; transition: all 0.25s;
  }
  .gate-no:hover { border-color: rgba(255,255,255,0.2); color: var(--mid); }
  .gate-note {
    font-size: 0.72rem; color: rgba(74,80,112,0.6);
    max-width: 340px; line-height: 1.65;
    position: relative; z-index: 1;
  }

  /* ══════════════ NAV ══════════════ */
  nav {
    position: fixed; top:0; left:0; right:0; z-index:100;
    height: 64px;
    background: rgba(7,8,16,0.97);
    border-bottom: 1px solid rgba(13,203,223,0.15);
    backdrop-filter: blur(16px);
    display: flex; align-items: center;
    justify-content: space-between; padding: 0 52px;
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  nav.scrolled {
    border-bottom-color: rgba(232,22,110,0.2);
    box-shadow: 0 4px 32px rgba(232,22,110,0.08);
  }
  .nav-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  .nav-emblem {
    width: 32px; height: 32px; border-radius: 50%;
    border: 1.5px solid var(--cyan);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.78rem;
    box-shadow: 0 0 12px var(--glow-c);
    flex-shrink: 0;
    background: rgba(13,203,223,0.06);
  }
  .nav-name {
    font-family: 'Syne', sans-serif;
    font-size: 1.05rem; font-weight: 800;
    letter-spacing: -0.01em; color: var(--white); line-height: 1.1;
  }
  .nav-name small {
    display: block; font-family: 'Space Grotesk', sans-serif;
    font-size: 0.5rem; font-weight: 500;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--cyan); margin-top: 1px;
  }
  .nav-links { list-style: none; display: flex; gap: 2px; }
  .nav-links a {
    font-size: 0.83rem; font-weight: 500;
    text-decoration: none; color: var(--mid);
    padding: 7px 14px; border-radius: 4px;
    letter-spacing: 0.02em; transition: all 0.2s;
  }
  .nav-links a:hover { color: var(--white); background: rgba(255,255,255,0.05); }
  .nav-cta {
    font-family: 'Syne', sans-serif;
    font-size: 0.76rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    background: linear-gradient(135deg, var(--pink), var(--purple));
    color: var(--white); border: none;
    padding: 10px 22px; border-radius: 3px;
    cursor: pointer; text-decoration: none;
    box-shadow: 0 2px 14px var(--glow-p);
    transition: all 0.2s;
  }
  .nav-cta:hover { transform: translateY(-1px); box-shadow: 0 4px 22px rgba(232,22,110,0.4); }
  .nav-menu-btn { display: none; }

  /* ══════════════ HERO ══════════════ */
  #hero {
    padding-top: 64px; min-height: 100vh;
    background: var(--black);
    display: grid; grid-template-columns: 1fr 420px;
    position: relative; overflow: hidden;
  }
  /* City skyline gradient bottom */
  .hero-cityline {
    position: absolute; bottom: 0; left: 0; right: 0; height: 35%;
    background: linear-gradient(0deg,
      rgba(232,22,110,0.07) 0%,
      rgba(108,60,191,0.05) 40%,
      transparent 100%);
    pointer-events: none;
  }
  /* Top cyan glow */
  .hero-glow-top {
    position: absolute; top: 0; left: 0; right: 0; height: 30%;
    background: radial-gradient(ellipse 80% 60% at 40% 0%, rgba(13,203,223,0.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-left {
    display: flex; align-items: center;
    padding: 90px 68px 80px; position: relative; z-index: 1;
  }
  .hero-right {
    background: var(--panel);
    border-left: 1px solid rgba(13,203,223,0.1);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 80px 44px 60px; gap: 14px;
    position: relative; z-index: 1; overflow: hidden;
  }
  .hero-right::before {
    content: '';
    position: absolute; top:0; left:0; right:0; height:2px;
    background: linear-gradient(90deg, var(--pink), var(--purple), var(--cyan));
  }
  /* Ring lights from photo */
  .hero-rings {
    position: absolute; top: 20px; right: 20px;
    display: flex; gap: 8px; opacity: 0.15;
  }
  .h-ring {
    border-radius: 50%;
    border: 2px solid var(--white);
    animation: hrRing 4s ease-in-out infinite;
  }
  .h-ring:nth-child(1){ width:48px; height:48px; margin-top:16px; }
  .h-ring:nth-child(2){ width:64px; height:64px; animation-delay:1s; }
  .h-ring:nth-child(3){ width:48px; height:48px; margin-top:16px; animation-delay:2s; }
  @keyframes hrRing { 0%,100%{opacity:0.8;} 50%{opacity:0.3;} }

  .hero-content { max-width: 580px; }
  .hc-eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 0.64rem; font-weight: 600;
    letter-spacing: 0.32em; text-transform: uppercase;
    color: var(--cyan); margin-bottom: 22px;
    animation: fadeUp 0.7s 0.2s both;
  }
  .hc-eyebrow::before { content:''; width:22px; height:1px; background:var(--cyan); box-shadow:0 0 8px var(--cyan); }

  .hc-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(3rem, 7.5vw, 6.5rem);
    font-weight: 800; letter-spacing: -0.03em;
    line-height: 0.92; color: var(--white);
    margin-bottom: 8px;
    animation: fadeUp 0.7s 0.4s both;
  }
  .hc-title .the { color: var(--cyan); text-shadow: 0 0 24px var(--glow-c); font-size: 0.55em; display: block; letter-spacing: 0.1em; }
  .hc-title .space { color: var(--white); }
  .hc-title .station {
    color: var(--pink);
    text-shadow: 0 0 30px var(--glow-p), 0 0 60px rgba(232,22,110,0.2);
    display: block;
  }

  .hc-sub {
    font-family: 'Syne', sans-serif;
    font-size: clamp(0.85rem, 1.8vw, 1.1rem);
    font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.2); margin-bottom: 28px;
    animation: fadeUp 0.7s 0.55s both;
  }
  .hc-desc {
    font-size: 1rem; font-weight: 400;
    color: rgba(242,244,255,0.5);
    line-height: 1.82; max-width: 480px;
    margin-bottom: 44px; letter-spacing: 0.01em;
    animation: fadeUp 0.7s 0.7s both;
  }
  .hc-btns { display: flex; gap: 12px; flex-wrap: wrap; animation: fadeUp 0.7s 0.9s both; }

  .btn-neon {
    font-family: 'Syne', sans-serif;
    font-size: 0.8rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    background: linear-gradient(135deg, var(--pink), var(--purple));
    color: var(--white); border: none;
    padding: 15px 34px; border-radius: 3px;
    cursor: pointer; text-decoration: none;
    display: inline-flex; align-items: center; gap: 8px;
    box-shadow: 0 4px 24px var(--glow-p);
    transition: all 0.25s;
  }
  .btn-neon:hover { transform: translateY(-3px); box-shadow: 0 8px 36px rgba(232,22,110,0.4); }
  .btn-outline-c {
    font-family: 'Syne', sans-serif;
    font-size: 0.8rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    background: transparent; color: var(--cyan);
    border: 1.5px solid var(--cyan);
    padding: 15px 28px; border-radius: 3px;
    cursor: pointer; text-decoration: none;
    display: inline-flex; align-items: center; gap: 8px;
    box-shadow: 0 0 14px rgba(13,203,223,0.15);
    transition: all 0.25s;
  }
  .btn-outline-c:hover { background: rgba(13,203,223,0.08); box-shadow: 0 0 24px var(--glow-c); }

  /* Hero right info */
  .hr-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px; padding: 18px 22px;
    width: 100%; max-width: 300px;
    position: relative; z-index: 1;
    transition: border-color 0.2s;
    animation: fadeUp 0.7s 0.5s both;
  }
  .hr-card:hover { border-color: rgba(13,203,223,0.25); }
  .hr-label {
    font-size: 0.56rem; font-weight: 600;
    letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--cyan); margin-bottom: 5px; opacity: 0.8;
  }
  .hr-val {
    font-family: 'Syne', sans-serif;
    font-size: 0.92rem; font-weight: 700;
    color: var(--white); line-height: 1.35; letter-spacing: -0.01em;
  }
  .hr-sub { font-size: 0.74rem; color: var(--mid); margin-top: 3px; font-weight: 400; }
  .open-chip {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(13,203,223,0.08);
    border: 1px solid rgba(13,203,223,0.2);
    border-radius: 3px; padding: 10px 20px;
    font-family: 'Syne', sans-serif;
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--cyan-mid);
    position: relative; z-index: 1;
    animation: fadeUp 0.7s 0.75s both; margin-top: 4px;
  }
  .pulse-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #7ddd9a; box-shadow: 0 0 8px #7ddd9a;
    animation: blk 2s infinite;
  }
  @keyframes blk { 0%,100%{opacity:1;} 50%{opacity:0.2;} }

  @media(max-width:960px){
    #hero{ grid-template-columns:1fr; }
    .hero-right{ border-left:none; border-top:1px solid rgba(13,203,223,0.1); padding:40px 28px 56px; align-items:flex-start; }
    .hr-card{ max-width:100%; }
    .hero-left{ padding:60px 28px 36px; }
  }

  /* ══════════════ INFO BAR ══════════════ */
  #info-bar {
    background: linear-gradient(135deg, var(--pink) 0%, var(--purple) 100%);
    padding: 13px 52px;
    display: flex; align-items: center;
    justify-content: center; gap: 44px; flex-wrap: wrap;
    position: relative; z-index: 1;
  }
  .ib-item {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.84rem; font-weight: 600;
    color: rgba(255,255,255,0.85);
  }
  .ib-item strong { color: var(--white); }
  .ib-sep { color: rgba(255,255,255,0.3); }

  /* ══════════════ SECTIONS ══════════════ */
  section { position: relative; z-index: 1; }
  .wrap { max-width: 1160px; margin: 0 auto; padding: 96px 52px; }
  .eyebrow {
    font-size: 0.62rem; font-weight: 600;
    letter-spacing: 0.32em; text-transform: uppercase;
    color: var(--cyan); margin-bottom: 10px;
    display: flex; align-items: center; gap: 10px;
  }
  .eyebrow::before { content:''; width:18px; height:1px; background:var(--cyan); box-shadow:0 0 6px var(--cyan); }
  .h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.9rem, 4.5vw, 3.2rem);
    font-weight: 800; letter-spacing: -0.02em;
    line-height: 1.05; color: var(--white); margin-bottom: 10px;
  }
  .h2 .p { color: var(--pink); text-shadow: 0 0 20px var(--glow-p); }
  .h2 .c { color: var(--cyan); text-shadow: 0 0 20px var(--glow-c); }
  .h2-dark {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.9rem, 4.5vw, 3.2rem);
    font-weight: 800; letter-spacing: -0.02em;
    line-height: 1.05; color: var(--black); margin-bottom: 10px;
  }
  .h2-dark .p { color: var(--pink); }

  /* ══════════════ MENU ══════════════ */
  #menu { background: var(--deep); }
  .menu-intro p {
    font-size: 1rem; color: rgba(216,218,240,0.5);
    line-height: 1.75; max-width: 500px; margin: 10px 0 52px; font-weight: 400;
  }
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(162px,1fr));
    gap: 12px;
  }
  .mc {
    background: var(--card);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 4px; padding: 30px 14px 22px;
    text-align: center; cursor: pointer;
    transition: all 0.3s; position: relative; overflow: hidden;
  }
  .mc::before {
    content: '';
    position: absolute; top:0; left:0; right:0; height:2px;
    background: linear-gradient(90deg, var(--pink), var(--cyan));
    transform: scaleX(0); transition: transform 0.3s;
  }
  .mc:hover { border-color: rgba(232,22,110,0.3); transform: translateY(-4px); box-shadow: 0 10px 30px rgba(0,0,0,0.4), 0 0 20px rgba(232,22,110,0.08); }
  .mc:hover::before { transform: scaleX(1); }
  .mc-icon { font-size: 2rem; margin-bottom: 12px; display: block; }
  .mc-name {
    font-family: 'Syne', sans-serif;
    font-size: 0.84rem; font-weight: 700;
    letter-spacing: 0.04em; color: var(--white); margin-bottom: 4px;
  }
  .mc-note { font-size: 0.72rem; color: var(--muted); font-weight: 400; }

  /* ══════════════ TRANSMISSION STRIP ══════════════ */
  #transmission {
    background: var(--navy);
    border-top: 1px solid rgba(232,22,110,0.15);
    border-bottom: 1px solid rgba(13,203,223,0.15);
    padding: 60px 52px; position: relative; overflow: hidden;
  }
  /* Neon city glow BG */
  #transmission::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 80% at 90% 50%, rgba(232,22,110,0.08), transparent 70%),
      radial-gradient(ellipse 50% 70% at 10% 50%, rgba(13,203,223,0.06), transparent 70%);
    pointer-events: none;
  }
  .ts-inner {
    max-width: 1160px; margin: 0 auto;
    display: flex; align-items: center;
    justify-content: space-between; gap: 40px; flex-wrap: wrap;
    position: relative; z-index: 1;
  }
  .ts-tag { font-size: 0.62rem; font-weight: 600; letter-spacing: 0.3em; text-transform: uppercase; color: var(--pink); margin-bottom: 10px; }
  .ts-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.8rem,4vw,3rem); font-weight: 800;
    letter-spacing: -0.02em; color: var(--white); line-height: 1.1; margin-bottom: 12px;
  }
  .ts-title .glow-p { color: var(--pink); text-shadow: 0 0 24px var(--glow-p); }
  .ts-desc { font-size: 1rem; color: rgba(216,218,240,0.5); line-height: 1.72; max-width: 500px; font-weight: 400; }
  .ts-stats { display: flex; gap: 36px; flex-wrap: wrap; margin-top: 28px; }
  .ts-stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 2.8rem; font-weight: 800;
    letter-spacing: -0.03em; line-height: 1; color: var(--cyan);
    text-shadow: 0 0 20px var(--glow-c);
  }
  .ts-stat-label {
    font-size: 0.65rem; font-weight: 600;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--muted); margin-top: 2px;
  }
  .ts-btn {
    font-family: 'Syne', sans-serif;
    font-size: 0.8rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    background: linear-gradient(135deg, var(--pink), var(--purple));
    color: var(--white); border: none;
    padding: 16px 36px; border-radius: 3px; cursor: pointer; text-decoration: none;
    box-shadow: 0 4px 20px var(--glow-p);
    transition: all 0.25s; white-space: nowrap; align-self: center;
  }
  .ts-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(232,22,110,0.4); }

  /* ══════════════ WHY ══════════════ */
  #why { background: var(--panel); }
  .why-grid {
    display: grid; grid-template-columns: repeat(2,1fr);
    gap: 12px; margin-top: 52px;
  }
  @media(max-width:700px){ .why-grid{grid-template-columns:1fr;} }
  .wc {
    background: var(--card);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 4px; padding: 32px 28px;
    transition: all 0.3s; position: relative; overflow: hidden;
  }
  .wc::after {
    content: '';
    position: absolute; bottom:0; left:0; right:0; height:2px;
    background: linear-gradient(90deg, var(--pink), var(--cyan));
